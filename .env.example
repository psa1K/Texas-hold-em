# Texas Hold'em Poker — 环境变量模板
# 使用方法：复制为 .env 后填入真实密钥
#   Windows:  copy .env.example .env
#   Linux/macOS: cp .env.example .env
#
# 加载方式（任选其一）：
#   1. 在系统/终端中手动 export / set 对应变量
#   2. 安装 python-dotenv 后由启动脚本加载（见 README）
#   3. IDE 运行配置中引用本 .env 文件
#
# 优先级：THP_LLM_* 环境变量 > config/llm_config.json > 代码默认值
# 核心游戏（规则 AI Bot）无需以下配置即可运行。

# ── 主力 LLM（与 config/llm_config.json 默认值对齐）────────────────────────
THP_LLM_PROVIDER=deepseek
THP_LLM_MODEL=deepseek-v4-pro
THP_LLM_API_KEY=

# 可选：覆盖 JSON 中的高级参数（取消注释后生效）
# THP_LLM_BASE_URL=https://api.deepseek.com
# THP_LLM_TIMEOUT=15
# THP_LLM_TEMPERATURE=0.1
# THP_LLM_MAX_TOKENS=200
# THP_LLM_CALL_FREQUENCY=critical

# ── 各 LLM 提供商 API Key ────────────────────────────────────────────────────
# 未设置 THP_LLM_API_KEY 时，将按 THP_LLM_PROVIDER 自动读取对应变量。
# 降级链（fallbacks）中的其他提供商也需配置对应 Key。

# 国内模型（当前项目默认）
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
GLM_API_KEY=
MOONSHOT_API_KEY=
MINIMAX_API_KEY=
ARK_API_KEY=
LONGCAT_API_KEY=

# 国际模型
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama 本地部署无需 API Key，默认端点 http://localhost:11434
# 使用 Ollama 时可将 THP_LLM_PROVIDER 设为 ollama，THP_LLM_MODEL 设为本地模型名
